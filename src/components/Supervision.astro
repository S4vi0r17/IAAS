---
---

<!-- SECTION 2: SUPERVISIÓN, INSPECCIÓN Y CONTROL TÉCNICO INTEGRAL -->
<section class="relative bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen">

      <!-- Left Column: Content -->
      <div class="flex flex-col justify-center px-6 sm:px-8 lg:px-12 py-12 lg:py-16">
        <!-- Title -->
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-4">
          Supervisión, Inspección y
          <span class="text-iaas-blue block">CONTROL TÉCNICO INTEGRAL</span>
        </h2>

        <!-- Subtitle -->
        <p class="text-sm text-iaas-gray leading-relaxed mb-8 max-w-lg">
          Garantizamos el éxito de sus proyectos mediante un control exhaustivo en las
          dimensiones técnica, administrativa, económica y contractual.
        </p>

        <!-- 2x2 Grid of Categories with descriptions -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
          <!-- Infraestructura Civil -->
          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors">
              <svg class="w-4 h-4 text-iaas-blue group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900 mb-1">Infraestructura Civil</h3>
              <p class="text-[11px] text-iaas-gray leading-relaxed">Carreteras, puentes, obras de saneamiento, edificaciones y obras de arte.</p>
            </div>
          </div>

          <!-- Energía y Redes -->
          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors">
              <svg class="w-4 h-4 text-iaas-blue group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900 mb-1">Energía y Redes</h3>
              <p class="text-[11px] text-iaas-gray leading-relaxed">Líneas de transmisión, subestaciones, redes de distribución y sistemas eléctricos.</p>
            </div>
          </div>

          <!-- Minería e Industria -->
          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors">
              <svg class="w-4 h-4 text-iaas-blue group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900 mb-1">Minería e Industria</h3>
              <p class="text-[11px] text-iaas-gray leading-relaxed">Plantas de procesamiento, instalaciones mineras y proyectos industriales.</p>
            </div>
          </div>

          <!-- Infraestructura Social -->
          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors">
              <svg class="w-4 h-4 text-iaas-blue group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900 mb-1">Infraestructura Social</h3>
              <p class="text-[11px] text-iaas-gray leading-relaxed">Hospitales, colegios, centros comunitarios y edificaciones de servicio público.</p>
            </div>
          </div>
        </div>

        <!-- Quote -->
        <blockquote class="border-l-2 border-iaas-blue/30 pl-4 mb-8">
          <p class="text-[11px] sm:text-xs text-iaas-gray italic leading-relaxed max-w-lg">
            "Nuestro trabajo abarca desde la pre-inversión hasta el mantenimiento, asegurando
            cumplimiento normativo y eficiencia financiera en sectores público y privado."
          </p>
        </blockquote>

        <!-- Bottom Tabs -->
        <div class="flex flex-wrap gap-2">
          <span class="px-4 py-2 text-xs font-semibold text-iaas-blue bg-iaas-light rounded hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer">Fiscalización</span>
          <span class="px-4 py-2 text-xs font-semibold text-iaas-blue bg-iaas-light rounded hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer">Consultoría</span>
          <span class="px-4 py-2 text-xs font-semibold text-iaas-blue bg-iaas-light rounded hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer">Interventoría</span>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div class="relative min-h-75 sm:min-h-100 lg:min-h-0">
        <img
          src="/images/supervision-site.jpeg"
          alt="Equipo de supervisión en obra de construcción"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Overlay -->
        <div class="absolute inset-0 bg-linear-to-l from-transparent to-white/10"></div>

        <!-- CONTROL INTEGRAL Badge with list -->
        <div class="absolute bottom-6 right-6 sm:bottom-8 sm:right-8 bg-white/95 backdrop-blur-sm rounded-lg px-5 py-4 shadow-lg">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-iaas-blue flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <p class="text-sm font-bold text-gray-900">CONTROL INTEGRAL</p>
          </div>
          <ul class="space-y-1.5 text-[11px] text-iaas-gray">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-iaas-blue shrink-0"></span>
              Técnico y Normativo
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-iaas-blue shrink-0"></span>
              Administrativo y Contractual
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-iaas-blue shrink-0"></span>
              Económico y Financiero
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>
