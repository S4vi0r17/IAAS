---
import { Picture } from 'astro:assets';
import heroEngineer from '../assets/hero-engineer.jpeg';
---

<!-- SECTION 1: HERO -->
<section class="relative min-h-screen bg-white overflow-hidden">
  <!-- Navbar -->
  <nav class="relative z-10 w-full">
    <div class="max-w-7xl mx-auto flex items-center justify-between px-6 sm:px-8 lg:px-12 py-5">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-extrabold text-iaas-blue tracking-tight">IAAS</span>
      </div>
      <button class="bg-iaas-blue text-white text-xs font-semibold px-5 py-2.5 rounded hover:bg-iaas-dark transition-colors cursor-pointer">
        IAAS #002
      </button>
    </div>
  </nav>

  <!-- Hero Content -->
  <div class="relative z-10 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 px-6 sm:px-8 lg:px-12 pt-8 sm:pt-12 lg:pt-16 pb-20 items-center min-h-[calc(100vh-80px)]">

    <!-- Left Column -->
    <div class="flex flex-col justify-center text-center lg:text-left">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.4rem] font-bold leading-tight text-gray-900 mb-4 sm:mb-6">
        Soluciones
        Integrales en
        <span class="text-iaas-blue">Gestión de Proyectos</span>
      </h1>
      <p class="text-sm text-iaas-gray max-w-md leading-relaxed mb-8 sm:mb-12 mx-auto lg:mx-0">
        Consultoría, Supervisión y Gerencia de Proyectos de
        Ingeniería y Construcción con estándares de excelencia.
      </p>

      <!-- Category Tags -->
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2 sm:gap-3 text-[10px] sm:text-[11px] font-semibold tracking-widest text-iaas-gray uppercase mt-auto">
        <span>Infraestructura</span>
        <span class="w-1 h-1 rounded-full bg-iaas-gray"></span>
        <span>Minería</span>
        <span class="w-1 h-1 rounded-full bg-iaas-gray"></span>
        <span>Energía</span>
        <span class="w-1 h-1 rounded-full bg-iaas-gray"></span>
        <span>SST</span>
      </div>
    </div>

    <!-- Right Column -->
    <div class="relative flex items-center justify-center order-first lg:order-last">
      <!-- Hero Image Container -->
      <div class="relative w-full max-w-sm sm:max-w-md lg:max-w-lg">
        <!-- Background shape -->
        <div class="absolute inset-0 bg-linear-to-br from-iaas-light to-white rounded-3xl -rotate-3 scale-105"></div>

        <!-- Main Image -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl aspect-4/3">
          <Picture
            src={heroEngineer}
            formats={['avif', 'webp']}
            alt="Ingeniero de IAAS supervisando proyecto de construcción"
            class="w-full h-full object-cover"
            widths={[400, 800, 1200]}
            sizes="(max-width: 640px) 400px, (max-width: 1024px) 800px, 1200px"
          />
          <!-- Overlay gradient -->
          <div class="absolute inset-0 bg-linear-to-t from-iaas-dark/20 to-transparent"></div>
        </div>

        <!-- Building overlay decoration -->
        <div class="absolute -top-4 -right-4 w-24 h-32 sm:w-32 sm:h-40 bg-iaas-light/50 rounded-xl -z-1"></div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="absolute bottom-0 left-0 right-0 border-t border-gray-100 bg-white/80 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between px-6 sm:px-8 lg:px-12 py-3 sm:py-4 gap-1 sm:gap-0">
      <span class="text-[10px] sm:text-xs text-iaas-gray">Consultoría en Gestión Integral de Proyectos</span>
      <span class="text-[10px] sm:text-xs font-semibold text-iaas-blue">Brochure Corporativo 2024</span>
    </div>
  </div>

  <!-- Decorative line on the left -->
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-linear-to-b from-iaas-blue via-iaas-accent to-transparent"></div>
</section>
